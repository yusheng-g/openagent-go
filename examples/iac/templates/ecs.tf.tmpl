# ECS (Elastic Cloud Server) Module
# {{ .ProjectName }} — {{ .Environment }}

resource "huaweicloud_compute_instance" "{{ .Name }}" {
  name              = "{{ .Name }}"
  image_id          = var.image_id
  flavor_id         = "{{ .Flavor }}"
  availability_zone = var.availability_zone

  system_disk_type = "SSD"
  system_disk_size = {{ .DiskSize }}

  vpc_id    = var.vpc_id
  subnet_id = var.subnet_id

  security_group_ids = [var.security_group_id]

  {{ if .PublicIP }}
  # Assign public IP for internet access
  eip_type = "5_bgp"
  bandwidth {
    share_type  = "PER"
    size        = {{ .Bandwidth }}
  }
  {{ end }}

  user_data = <<-EOF
#!/bin/bash
# {{ .ProjectName }} bootstrap
apt-get update -y
{{ .UserData }}
EOF

  tags = {
    Name        = "{{ .Name }}"
    Project     = var.project_name
    Environment = var.environment
    ManagedBy   = "openagent-iac"
  }
}

output "{{ .Name }}_id" {
  value = huaweicloud_compute_instance.{{ .Name }}.id
}

output "{{ .Name }}_public_ip" {
  value = huaweicloud_compute_instance.{{ .Name }}.public_ip
}

output "{{ .Name }}_private_ip" {
  value = huaweicloud_compute_instance.{{ .Name }}.private_ip
}
